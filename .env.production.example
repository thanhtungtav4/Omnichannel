# Production env template for the CRM VPS deploy. Copy to .env on the server,
# fill every <PLACEHOLDER>, then run `php artisan key:generate`.
# NEVER commit the real .env. See docs/DEPLOY_VPS.md.

APP_NAME="CRM Cockpit"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://<YOUR_DOMAIN>

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

BCRYPT_ROUNDS=12

# --- Tenant routing ---
# Root domain that hangs the tenant subdomains off, e.g. acme.qrf.vn.
APP_TENANT_DOMAIN=qrf.vn
# Reserved subdomains for out-of-tenant surfaces.
APP_ADMIN_SUBDOMAIN=admin
APP_WEBHOOK_SUBDOMAIN=webhook    # webhook.qrf.vn — provider ingress vhost (see docs/OPS_WEBHOOKS.md)

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Database (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=crm
DB_USERNAME=crm
DB_PASSWORD=<STRONG_DB_PASSWORD>

# --- Redis (cache / queue / sessions) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=<STRONG_REDIS_PASSWORD_OR_null>
REDIS_PORT=6379

# Use Redis in production, not the database driver.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=<YOUR_DOMAIN>

CACHE_STORE=redis
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (fill with your SMTP; log is fine to start) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@<YOUR_DOMAIN>"
MAIL_FROM_NAME="${APP_NAME}"

# --- Zalo personal sidecar (Node service on the same VPS) ---
# The sidecar posts X-Sidecar-Token to the CRM; store the SAME value as each
# ZALO_PERSONAL channel account's webhook_secret in the UI.
ZALO_SIDECAR_URL=http://127.0.0.1:4501
ZALO_SIDECAR_TOKEN=<STRONG_SIDECAR_TOKEN>

# --- Shopee Chat VN (specs/11_SHOPEE_CHAT_VN.md) ---
# Per-tenant partner_id + partner_key live in workspace_settings
# (encrypted) — set them via the admin UI or tinker, NOT here.
# These two are global config (same for every workspace):
SHOPEE_REGION=vn
SHOPEE_API_BASE=https://partner.shopeemobile.com/api/v2
# For local/sandbox dev, override SHOPEE_API_BASE to:
#   SHOPEE_API_BASE=https://partner.test-shopeemobile.com/api/v2

# --- TikTok Shop Chat VN (specs/13_TIKTOK_SHOP_VN.md) ---
# Per-tenant app_id + app_secret live in workspace_settings under
# tiktok.partner_credentials (encrypted). Region + API base are global.
# W1 SPIKE: confirm exact API base URL after spike (TikTok Open API vs
# Shop Partner API — different endpoints).
TIKTOK_REGION=vn
TIKTOK_API_BASE=https://open.tiktokapis.com/v2

VITE_APP_NAME="${APP_NAME}"
